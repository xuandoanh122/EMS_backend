# Copy file này thành .env và điền thông tin thực tế
# cp .env.example .env

# ── MSSQL Configuration ──────────────────────────────────────────────────────
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=ems_db
MSSQL_USERNAME=ems_server
MSSQL_PASSWORD=Maiyeuem123@

# Driver phải khớp với tên trong pyodbc.drivers()
# Kiểm tra: python -c "import pyodbc; print(pyodbc.drivers())"
MSSQL_DRIVER=ODBC Driver 17 for SQL Server

# ── Connection Pool ───────────────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── SQLite Fallback ───────────────────────────────────────────────────────────
SQLITE_BACKUP_PATH=ems_backup.db
